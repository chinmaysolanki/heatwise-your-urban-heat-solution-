{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/site_exposure_profile_v1.json",
  "title": "site_exposure_profile",
  "type": "object",
  "required": [
    "site_exposure_id",
    "project_id",
    "project_type",
    "surrounding_built_density",
    "heat_absorption_risk_score",
    "wind_risk_score",
    "water_retention_risk_score",
    "irrigation_need_risk_score",
    "privacy_exposure_score",
    "cooling_need_score",
    "biodiversity_opportunity_score",
    "maintenance_stress_score",
    "overall_site_complexity_score",
    "created_at"
  ],
  "properties": {
    "site_exposure_id": { "type": "string" },
    "project_id": { "type": "string" },
    "project_type": { "type": "string" },
    "orientation": { "type": ["string", "null"] },
    "floor_level": { "type": ["integer", "null"] },
    "surrounding_built_density": { "type": "string" },
    "roof_material": { "type": ["string", "null"] },
    "surface_type": { "type": ["string", "null"] },
    "sunlight_hours": { "type": ["number", "null"] },
    "shade_level": { "type": ["string", "null"] },
    "heat_absorption_risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "wind_risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "water_retention_risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "irrigation_need_risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "privacy_exposure_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "cooling_need_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "biodiversity_opportunity_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "maintenance_stress_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "overall_site_complexity_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
