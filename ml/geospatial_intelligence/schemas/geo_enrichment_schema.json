{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/geo_enrichment_snapshot_v1.json",
  "title": "geo_enrichment_snapshot",
  "type": "object",
  "required": [
    "geo_enrichment_snapshot_id",
    "project_id",
    "enrichment_created_at",
    "geo_feature_payload_json",
    "microclimate_feature_payload_json",
    "site_exposure_payload_json",
    "overall_geo_confidence"
  ],
  "properties": {
    "geo_enrichment_snapshot_id": { "type": "string" },
    "project_id": { "type": "string" },
    "recommendation_session_id": { "type": ["string", "null"] },
    "geo_context_id": { "type": ["string", "null"] },
    "microclimate_snapshot_id": { "type": ["string", "null"] },
    "site_exposure_id": { "type": ["string", "null"] },
    "enrichment_created_at": { "type": "string", "format": "date-time" },
    "geo_feature_payload_json": { "type": "string" },
    "microclimate_feature_payload_json": { "type": "string" },
    "site_exposure_payload_json": { "type": "string" },
    "overall_geo_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
