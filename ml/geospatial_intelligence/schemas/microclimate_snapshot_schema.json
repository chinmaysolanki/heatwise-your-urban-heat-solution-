{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/microclimate_snapshot_v1.json",
  "title": "microclimate_snapshot",
  "type": "object",
  "required": ["microclimate_snapshot_id", "project_id", "captured_at", "month_of_year", "source_type", "source_confidence"],
  "properties": {
    "microclimate_snapshot_id": { "type": "string" },
    "project_id": { "type": "string" },
    "captured_at": { "type": "string", "format": "date-time" },
    "month_of_year": { "type": "integer", "minimum": 1, "maximum": 12 },
    "avg_day_temp_c": { "type": ["number", "null"] },
    "avg_night_temp_c": { "type": ["number", "null"] },
    "summer_peak_temp_c": { "type": ["number", "null"] },
    "humidity_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "rainfall_level": { "type": ["string", "null"] },
    "wind_exposure_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "sun_exposure_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "shade_cover_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "reflected_heat_risk_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "dust_exposure_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "runoff_risk_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "water_availability_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "seasonal_heat_stress_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "source_type": { "type": "string" },
    "source_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
