{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "installer_profile",
  "type": "object",
  "required": [
    "installer_id",
    "installer_name",
    "service_regions",
    "supported_project_types",
    "supported_solution_types",
    "supported_budget_bands",
    "min_job_size_sqft",
    "irrigation_capability",
    "structural_install_capability",
    "shade_system_capability",
    "edible_garden_capability",
    "maintenance_service_available",
    "jobs_completed_count",
    "verification_status",
    "active_status",
    "created_at"
  ],
  "properties": {
    "installer_id": { "type": "string", "minLength": 1 },
    "installer_name": { "type": "string", "minLength": 1 },
    "service_regions": { "type": "array", "items": { "type": "string" } },
    "supported_project_types": { "type": "array", "items": { "type": "string" } },
    "supported_solution_types": { "type": "array", "items": { "type": "string" } },
    "supported_budget_bands": { "type": "array", "items": { "type": "string" } },
    "min_job_size_sqft": { "type": "number", "minimum": 0 },
    "max_job_size_sqft": { "type": ["number", "null"], "minimum": 0 },
    "irrigation_capability": { "type": "boolean" },
    "structural_install_capability": { "type": "boolean" },
    "shade_system_capability": { "type": "boolean" },
    "edible_garden_capability": { "type": "boolean" },
    "maintenance_service_available": { "type": "boolean" },
    "average_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "jobs_completed_count": { "type": "integer", "minimum": 0 },
    "verification_status": { "type": "string" },
    "active_status": { "type": "string" },
    "created_at": { "type": "string" },
    "metadata_json": {}
  },
  "additionalProperties": true
}
