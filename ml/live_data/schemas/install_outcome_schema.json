{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/install_outcome.json",
  "title": "Install outcome record",
  "type": "object",
  "required": ["project_id", "install_status"],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": ["string", "null"] },
    "telemetry_session_id": { "type": ["string", "null"] },
    "selected_candidate_snapshot_id": { "type": ["string", "null"] },
    "installer_id": { "type": ["string", "null"] },
    "install_status": {
      "type": "string",
      "enum": ["planned", "scheduled", "in_progress", "completed", "cancelled", "on_hold"]
    },
    "install_date": { "type": ["string", "null"], "format": "date-time" },
    "actual_install_cost_inr": { "type": ["number", "null"], "minimum": 0, "maximum": 5000000000 },
    "actual_maintenance_plan_inr": { "type": ["number", "null"], "minimum": 0, "maximum": 5000000000 },
    "installed_area_sqft": { "type": ["number", "null"], "minimum": 0 },
    "irrigation_installed": { "type": ["boolean", "null"] },
    "species_installed": {},
    "deviations_from_recommendation": {},
    "user_satisfaction_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "installer_feasibility_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "measured_temp_change_c": { "type": ["number", "null"] },
    "measured_surface_temp_change_c": { "type": ["number", "null"] },
    "plant_survival_rate_30d": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "plant_survival_rate_90d": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "maintenance_adherence_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "notes": { "type": ["string", "null"] },
    "idempotency_key": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
