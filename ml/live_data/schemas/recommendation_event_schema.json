{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/recommendation_session_create.json",
  "title": "Create recommendation telemetry session",
  "type": "object",
  "required": [
    "project_id",
    "model_version",
    "rules_version",
    "generator_source",
    "project_snapshot",
    "environment_snapshot",
    "preference_snapshot",
    "total_candidates",
    "latency_ms",
    "candidates"
  ],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": ["string", "null"] },
    "photo_session_id": { "type": ["string", "null"] },
    "model_version": { "type": "string", "minLength": 1 },
    "rules_version": { "type": "string", "minLength": 1 },
    "generator_source": {
      "type": "string",
      "enum": ["synthetic_bootstrap", "live_rules", "ml_ranker", "hybrid"]
    },
    "project_snapshot": { "type": "object" },
    "environment_snapshot": { "type": "object" },
    "preference_snapshot": { "type": "object" },
    "total_candidates": { "type": "integer", "minimum": 1, "maximum": 50 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "legacy_recommendation_run_id": { "type": ["string", "null"] },
    "idempotency_key": { "type": ["string", "null"] },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["candidate_rank", "candidate_source", "candidate_payload"],
        "properties": {
          "candidate_rank": { "type": "integer", "minimum": 1 },
          "candidate_score": { "type": ["number", "null"] },
          "candidate_source": { "type": "string", "minLength": 1 },
          "candidate_payload": { "type": "object" },
          "species_payload": { "type": ["object", "null"] },
          "estimated_install_cost_inr": { "type": ["number", "null"], "minimum": 0, "maximum": 5000000000 },
          "estimated_maintenance_cost_inr": { "type": ["number", "null"], "minimum": 0, "maximum": 5000000000 },
          "expected_temp_reduction_c": { "type": ["number", "null"] },
          "expected_surface_temp_reduction_c": { "type": ["number", "null"] },
          "feasibility_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "safety_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "heat_mitigation_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "water_efficiency_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "was_shown_to_user": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
