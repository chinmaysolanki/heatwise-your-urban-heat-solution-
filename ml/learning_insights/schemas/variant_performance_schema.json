{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/variant_performance_v1.json",
  "title": "variant_performance",
  "type": "object",
  "required": ["variant_performance_id", "window_start", "window_end", "created_at"],
  "properties": {
    "variant_performance_id": { "type": "string" },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "experiment_id": { "type": ["string", "null"] },
    "rollout_variant": { "type": ["string", "null"] },
    "recommendation_type": { "type": ["string", "null"] },
    "scenario_usage_tag": { "type": ["string", "null"] },
    "report_dossier_type": { "type": ["string", "null"] },
    "generator_source": { "type": ["string", "null"] },
    "rules_version": { "type": ["string", "null"] },
    "model_version": { "type": ["string", "null"] },
    "session_count": { "type": "integer", "minimum": 0 },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "avg_blended_score": { "type": ["number", "null"] },
    "avg_latency_ms": { "type": ["number", "null"] },
    "verified_install_count": { "type": "integer", "minimum": 0 },
    "dossier_created_count": { "type": "integer", "minimum": 0 },
    "followup_completed_count": { "type": "integer", "minimum": 0 },
    "commercial_installed_count": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
