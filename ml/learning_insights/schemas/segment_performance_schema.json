{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/segment_performance_v1.json",
  "title": "segment_performance",
  "type": "object",
  "required": [
    "segment_performance_id",
    "window_start",
    "window_end",
    "segment_key",
    "metrics_json",
    "sample_size",
    "created_at"
  ],
  "properties": {
    "segment_performance_id": { "type": "string" },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "segment_key": { "type": "string", "minLength": 1 },
    "project_type": { "type": ["string", "null"] },
    "climate_zone": { "type": ["string", "null"] },
    "budget_band": { "type": ["string", "null"] },
    "region": { "type": ["string", "null"] },
    "user_type": { "type": ["string", "null"] },
    "installer_availability_band": { "type": ["string", "null"] },
    "personalization_confidence_band": { "type": ["string", "null"] },
    "metrics_json": { "type": "string" },
    "sample_size": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
