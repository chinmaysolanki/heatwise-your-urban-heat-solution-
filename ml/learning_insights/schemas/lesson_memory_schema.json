{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/lesson_memory_v1.json",
  "title": "lesson_memory",
  "type": "object",
  "required": [
    "lesson_memory_id",
    "lesson_key",
    "polarity",
    "confidence_band",
    "summary_structured_json",
    "evidence_refs_json",
    "created_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "lesson_memory_id": { "type": "string" },
    "lesson_key": { "type": "string", "minLength": 1 },
    "polarity": { "type": "string", "enum": ["works", "fails", "mixed"] },
    "confidence_band": { "type": "string", "enum": ["low", "medium", "high"] },
    "summary_structured_json": { "type": "string" },
    "evidence_refs_json": { "type": "string" },
    "related_segment_key": { "type": ["string", "null"] },
    "related_recommendation_patterns_json": { "type": ["string", "null"] },
    "effective_from": { "type": ["string", "null"], "format": "date-time" },
    "effective_to": { "type": ["string", "null"], "format": "date-time" },
    "created_by": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
