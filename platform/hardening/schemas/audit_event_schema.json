{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.local/schemas/audit_event_v1.json",
  "title": "PlatformAuditEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["audit_event_type", "subsystem", "actor_type", "action", "outcome", "payload"],
  "properties": {
    "audit_event_type": { "type": "string", "minLength": 1, "maxLength": 256 },
    "subsystem": {
      "type": "string",
      "enum": [
        "recommendation_runtime",
        "pricing",
        "supply",
        "installer_ops",
        "reporting",
        "retraining_registry",
        "integrations",
        "analytics"
      ]
    },
    "actor_type": { "type": "string", "enum": ["user", "system", "api_client", "ops"] },
    "actor_id": { "type": "string", "pattern": "^c[a-z0-9]{24,}$" },
    "entity_type": { "type": "string", "maxLength": 128 },
    "entity_id": { "type": "string", "pattern": "^c[a-z0-9]{24,}$" },
    "action": { "type": "string", "minLength": 1, "maxLength": 256 },
    "outcome": { "type": "string", "enum": ["success", "denied", "error", "partial"] },
    "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
    "payload": { "type": "object" },
    "correlation_id": { "type": "string", "maxLength": 128 },
    "metadata": { "type": "object" }
  }
}
