{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatwise.app/schemas/unit_economics_snapshot_v1.json",
  "title": "unit_economics_snapshot",
  "type": "object",
  "required": [
    "unit_economics_snapshot_id",
    "window_start",
    "window_end",
    "total_projects",
    "total_quote_requests",
    "total_quotes_received",
    "total_quote_acceptances",
    "total_installs_completed",
    "created_at"
  ],
  "properties": {
    "unit_economics_snapshot_id": { "type": "string" },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "region": { "type": ["string", "null"] },
    "project_type": { "type": ["string", "null"] },
    "source_channel": { "type": ["string", "null"] },
    "total_projects": { "type": "integer", "minimum": 0 },
    "total_quote_requests": { "type": "integer", "minimum": 0 },
    "total_quotes_received": { "type": "integer", "minimum": 0 },
    "total_quote_acceptances": { "type": "integer", "minimum": 0 },
    "total_installs_completed": { "type": "integer", "minimum": 0 },
    "quote_request_to_quote_received_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "quote_received_to_acceptance_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "acceptance_to_install_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "install_conversion_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "avg_revenue_per_project_inr": { "type": ["number", "null"] },
    "avg_revenue_per_install_inr": { "type": ["number", "null"] },
    "avg_platform_margin_inr": { "type": ["number", "null"] },
    "avg_quote_value_inr": { "type": ["number", "null"] },
    "avg_final_install_value_inr": { "type": ["number", "null"] },
    "avg_time_to_quote_hours": { "type": ["number", "null"], "minimum": 0 },
    "avg_time_to_install_days": { "type": ["number", "null"], "minimum": 0 },
    "refund_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "repeat_service_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata_json": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
