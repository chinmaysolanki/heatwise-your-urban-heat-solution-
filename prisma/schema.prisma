  startedAt                   DateTime?
  completedAt                 DateTime?
  cancelledAt                 DateTime?
  cancellationReason          String?
  cancellationReasonCodesJson String?
  estimatedCostInr            Float?
  finalCostInr                Float?
  installPlanJson             String
  jobNotes                    String?

  quoteRequest      InstallerQuoteRequest            @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  project           Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User?                            @relation(fields: [userId], references: [id], onDelete: SetNull)
  installer         InstallerProfile                 @relation(fields: [installerId], references: [id], onDelete: Cascade)
