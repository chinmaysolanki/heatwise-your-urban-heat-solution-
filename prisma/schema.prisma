/// Post-install follow-up plan (7d / 30d / 90d / 180d checkpoints).
model LongitudinalFollowupSchedule {
  id                    String   @id @default(cuid())
  projectId             String
  userId                String?
  verifiedInstallId     String?
  baselineAt            DateTime
  scheduleStatus        String   @default("active")
