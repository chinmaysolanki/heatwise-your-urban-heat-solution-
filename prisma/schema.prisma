// Operational schema: same models deploy to Postgres in production (set provider + DATABASE_URL).
// Local dev may use SQLite; enums use String where SQLite lacks native enum.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String   @id @default(cuid())
  name                   String   @default("")
  email                  String?  @unique
  password               String?
  phoneNumber            String?  @unique
  phoneVerified          Boolean  @default(false)
  profileCompleted       Boolean  @default(false)
  city                   String?
  state                  String?
  country                String?
  age                    Int?
  gardeningInterestScore Int?
  createdAt              DateTime @default(now())
  projects               Project[]
  settings               UserSettings?
  userPreferences        UserPreference[]
  telemetrySessions      RecommendationTelemetrySession[]
  installOutcomes        InstallOutcomeRecord[]
  installerQuoteRequests InstallerQuoteRequest[]
  installerInstallJobs   InstallerInstallJob[]
  longitudinalFollowupSchedules LongitudinalFollowupSchedule[]
  revenueEvents                  RevenueEvent[]
  leadFunnelEvents               LeadFunnelEvent[]
  recommendationDossiers         RecommendationDossier[]
  consentRecords                 UserConsentRecord[]
  governancePolicyFlags          GovernancePolicyFlag[]
  governanceReviewsRelated       GovernanceReviewRecord[] @relation("GovernanceReviewRelatedUser")
}

model PhoneOtp {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  codeHash    String
  expiresAt   DateTime
  attempts    Int      @default(0)
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id])
  units          String  @default("metric")
  darkMode       Boolean @default(false)
  notifications  Boolean @default(true)
}

model Project {
  id                   String                @id @default(cuid())
  name                 String
  location             String
  surfaceType          String
  primaryGoal          String
  area                 Float
  obstacles            String
  userId               String
  user                 User                  @relation(fields: [userId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  status               String                @default("Draft")
  analysis             Analysis?
  installationRequest  InstallationRequest?
  spaces               Space[]
  userPreferences      UserPreference[]
  recommendationRuns   RecommendationRun[]
  telemetrySessions    RecommendationTelemetrySession[]
  installOutcomes      InstallOutcomeRecord[]
  installerQuoteRequests InstallerQuoteRequest[]
  installerInstallJobs   InstallerInstallJob[]
  verifiedInstallRecords VerifiedInstallRecord[]
  outcomeVerifications   OutcomeVerificationRecord[]
  longitudinalFollowupSchedules LongitudinalFollowupSchedule[]
  longitudinalRemeasurements      LongitudinalRemeasurement[]
  recommendationConstraintSnapshots RecommendationConstraintSnapshot[]
  costEstimateSnapshots            CostEstimateSnapshot[]
  quoteComparisonRecords           QuoteComparisonRecord[]
  budgetFitAssessments             BudgetFitAssessment[]
  geoContexts                      GeoContext[]
  microclimateSnapshots            MicroclimateSnapshot[]
  siteExposureProfiles             SiteExposureProfile[]
  geoEnrichmentSnapshots         GeoEnrichmentSnapshot[]
  revenueEvents                  RevenueEvent[]
  leadFunnelEvents               LeadFunnelEvent[]
  commercialOutcomes             CommercialOutcome[]
  recommendationDossiers         RecommendationDossier[]
  installerExecutionSummaries  InstallerExecutionSummary[]
  governancePolicyFlags        GovernancePolicyFlag[]
  governanceReviewRecords      GovernanceReviewRecord[] @relation("GovernanceReviewRelatedProject")
}

model Space {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  label       String?
  areaSqm     Float?
  lengthM     Float?   @map("length_m")
  widthM      Float?   @map("width_m")
  aspect      String?
  floorLevel  Int?
  spaceKind   String   @default("ROOFTOP")
  indoor      Boolean  @default(false)
  waterAccess     String? @map("water_access")
  drainageQuality String? @map("drainage_quality")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  environmentSnapshots EnvironmentSnapshot[]
  recommendationRuns   RecommendationRun[]

  @@index([projectId])
}

model EnvironmentSnapshot {
  id            String   @id @default(cuid())
  spaceId       String
  space         Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tempC         Float?
  sunIndex      Float?
  windIndex     Float?
  humidityPct   Float?
  soilPh        Float?
  soilMoisture  Float?
  notes         String?
  sunlightHours     Float?  @map("sunlight_hours")
  shadeLevel        String? @map("shade_level")
  peakSurfaceTempC  Float?  @map("peak_surface_temp_c")
  rainfallLevel     String? @map("rainfall_level")
  heatIslandScore   Float?  @map("heat_island_score")
  createdAt     DateTime @default(now())

  recommendationRuns RecommendationRun[]
  photoSessions      PhotoSession[]

  @@index([spaceId])
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  gardeningScore    Int?
  budgetBand        Int?
  maintenanceBand   Int?
  waterConstraint   String?
  preferredStyle      String?  @map("preferred_style")
  ediblePreference    Boolean? @map("edible_preference")
  floweringPreference Boolean? @map("flowering_preference")
  petSafeRequired     Boolean? @map("pet_safe_required")
  irrigationAllowed   Boolean? @map("irrigation_allowed")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  recommendationRuns RecommendationRun[]

  @@index([userId])
  @@index([projectId])
}

/// Canonical species row for rules, filtering, and ML labels (`code` → `species_<code>` in exports).
model SpeciesCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  displayName String
  /// Taxonomic / UX metadata (rule filters, explainability).
  scientificName String?
  family         String?
  category       String?
  /// Terrace/rooftop rule flags (also used for ML feature exports if needed).
  edible           Boolean  @default(false)
  flowering        Boolean  @default(false)
  petSafe          Boolean  @default(false) @map("pet_safe")
  droughtTolerant  Boolean  @default(false) @map("drought_tolerant")
  heatTolerant     Boolean  @default(false) @map("heat_tolerant")
  lowMaintenance   Boolean  @default(false) @map("low_maintenance")
  /// Typical acceptable direct-sun hours per day (container / roof context).
  minSunHours      Int?     @map("min_sun_hours")
  maxSunHours      Int?     @map("max_sun_hours")
  notes            String?
  /// JSON array of strings, e.g. ["monsoon_ok","wind_exposed"].
  tagsJson         String?  @map("tags_json")
  /// Rule & retrieval: legacy vocab (LOW | MED | HIGH) — optional if booleans are source of truth.
  droughtTolerance String?
  sunExposure      String?
  hardinessZoneMin Int?
  hardinessZoneMax Int?
  maxHeightCm      Float?
  growthHabit      String?
  nativeRangeNotes String?
  invasiveRisk     String?
  ruleTagsJson     String?
  mlWeight         Float?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recommendationCandidates RecommendationCandidate[]
  outcomeEvents            OutcomeEvent[]

  @@index([category])
  @@index([active])
  @@index([family])
  @@index([heatTolerant])
  @@index([droughtTolerant])
}

/// Legacy GPT-backed analysis persisted by removed `POST /api/analysis/run`. Kept for existing DB rows + project list; no current HTTP writer in app.
model Analysis {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id])
  score         Int
  coolingDrop   Float
  co2Annual     Float
  energySaving  Float
  confidence    Float
  plants        String
  createdAt     DateTime @default(now())
}

model InstallationRequest {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id])
  contactName   String
  email         String
  phone         String?
  contactMethod String
  timeline      String
  exportJson    String?
  createdAt     DateTime @default(now())
}

model RecommendationFeedbackEvent {
  id               String                  @id @default(cuid())
  eventId          String                  @unique
  userId           String?
  recommendationId String
  projectId        String?
  action           String
  timestamp        DateTime
  dwellMs          Int?
  scoreBefore      Float?
  scoreAfter       Float?
  notes            String?
  extra            String?
  createdAt        DateTime                @default(now())
  candidateId      String?
  candidate        RecommendationCandidate? @relation(fields: [candidateId], references: [id])
}

/// One recommendation request in a project/space context; training-quality rows should set project + space (+ optional snapshot).
model RecommendationRun {
  id                    String                    @id @default(cuid())
  createdAt             DateTime                  @default(now())
  input                 String
  durationMs            Int
  totalCandidates       Int
  candidates            RecommendationCandidate[]
  projectId             String?
  project               Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  photoSessionId        String?
  photoSession          PhotoSession?             @relation(fields: [photoSessionId], references: [id], onDelete: SetNull)
  spaceId               String?
  space                 Space?                    @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  environmentSnapshotId String?
  environmentSnapshot   EnvironmentSnapshot?      @relation(fields: [environmentSnapshotId], references: [id], onDelete: SetNull)
  userPreferenceId      String?
  userPreference        UserPreference?           @relation(fields: [userPreferenceId], references: [id], onDelete: SetNull)
  outcomeEvents         OutcomeEvent[]
  telemetrySession      RecommendationTelemetrySession?
  learningTelemetryEvents RecommendationTelemetryEvent[]

  @@index([projectId])
  @@index([photoSessionId])
  @@index([spaceId])
  @@index([environmentSnapshotId])
  @@index([userPreferenceId])
  @@index([projectId, spaceId])
}

/// Phase 8–9: append-only server observation per POST /api/recommendations/generate (rollout metrics + guardrails + failure paths).
model RecommendationRuntimeObservation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  projectId String?

  /// success | client_error | handler_error
  observationKind String @default("success")
  /// HTTP status intended for this observation (200 even if layout failed; 400/500 for errors).
  outcomeHttpStatus Int?
  errorCode           String?
  errorMessageTruncated String?

  /// Stable request identity (Phase 9 dedupe).
  requestFingerprint String @default("unknown")
  /// canonical | shadow_experiment | compat_client
  trafficChannel     String @default("canonical")

  /// python_usable | catalog_hybrid_ts | rules_only_emergency | empty_response | handler_error | client_error
  runtimePathCategory String
  generatorSource     String?
  mlMode              String?
  heatwiseServingOk   Boolean?

  candidateTotal               Int
  candidateOpen                Int
  candidatesWithSpeciesCode    Int
  layoutRecommendationCount     Int @default(0)
  layoutUnresolvedIdentityCount Int @default(0)

  layoutSlateStatus String?
  layoutFailureCode String?

  /// Parsed from mlErrors, e.g. catalog_fallback_reason:python_nonzero_exit
  fallbackReasonTag String?
  mlErrorsTruncated String?

  @@index([createdAt])
  @@index([runtimePathCategory])
  @@index([generatorSource])
  @@index([projectId])
  @@index([requestFingerprint])
  @@index([trafficChannel])
  @@index([observationKind])
}

/// ML-oriented recommendation session: immutable snapshots + versioning (append-only events elsewhere).
model RecommendationTelemetrySession {
  id                        String   @id @default(cuid())
  projectId                 String
  userId                    String?
  photoSessionId            String?
  generatedAt               DateTime @default(now())
  modelVersion              String
  rulesVersion              String
  generatorSource           String
  projectSnapshotJson       String
  environmentSnapshotJson   String
  preferenceSnapshotJson    String
  totalCandidates           Int
  latencyMs                 Int
  legacyRecommendationRunId String?  @unique
  idempotencyKey            String?  @unique

  project                 Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                    User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  photoSession            PhotoSession?           @relation(fields: [photoSessionId], references: [id], onDelete: SetNull)
  legacyRun               RecommendationRun?      @relation(fields: [legacyRecommendationRunId], references: [id], onDelete: SetNull)
  candidateSnapshots      RecommendationCandidateSnapshot[]
  telemetryEvents         RecommendationTelemetryEvent[]
  installOutcomes         InstallOutcomeRecord[]
  installerQuoteRequests  InstallerQuoteRequest[]
  recommendationConstraintSnapshots RecommendationConstraintSnapshot[]
  costEstimateSnapshots             CostEstimateSnapshot[]
  quoteComparisonRecords          QuoteComparisonRecord[]
  geoEnrichmentSnapshots          GeoEnrichmentSnapshot[]
  revenueEvents                   RevenueEvent[]
  leadFunnelEvents                LeadFunnelEvent[]
  recommendationDossiers          RecommendationDossier[]

  @@index([projectId])
  @@index([userId])
  @@index([photoSessionId])
  @@index([generatedAt])
}

/// Exact candidate card as shown to the user (training reproducibility).
model RecommendationCandidateSnapshot {
  id                            String   @id @default(cuid())
  sessionId                     String
  candidateRank                 Int
  candidateScore                Float?
  candidateSource               String
  candidatePayloadJson          String
  speciesPayloadJson            String?
  estimatedInstallCostInr       Float?
  estimatedMaintenanceCostInr   Float?
  expectedTempReductionC        Float?
  expectedSurfaceTempReductionC Float?
  feasibilityScore              Float?
  safetyScore                   Float?
  heatMitigationScore           Float?
  waterEfficiencyScore          Float?
  wasShownToUser                Boolean  @default(false)

  session           RecommendationTelemetrySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  telemetryEvents   RecommendationTelemetryEvent[]
  selectedOutcomes  InstallOutcomeRecord[]
  installerQuoteRequests InstallerQuoteRequest[]
  installerInstallJobs   InstallerInstallJob[]
  costEstimateSnapshots  CostEstimateSnapshot[]
  quoteComparisonRecords QuoteComparisonRecord[]
  budgetFitAssessments   BudgetFitAssessment[]
  selectedInDossiers     RecommendationDossier[] @relation("DossierSelectedCandidate")

  @@unique([sessionId, candidateRank])
  @@index([sessionId])
}

/// Append-only user/installer telemetry (explicit + implicit learning signals).
model RecommendationTelemetryEvent {
  id                  String   @id @default(cuid())
  feedbackEventId     String   @unique
  sessionId           String
  candidateSnapshotId String?
  projectId           String
  userId              String?
  eventType           String
  eventTimestamp      DateTime @default(now())
  eventSource         String
  screenName          String?
  uiPosition          Int?
  dwellTimeMs         Int?
  eventValue          String?
  metadataJson        String?
  /// Optional FK for export joins without parsing metadata (mirrors session.legacyRecommendationRunId when set).
  recommendationRunId String?
  recommendationRun    RecommendationRun? @relation(fields: [recommendationRunId], references: [id], onDelete: SetNull)

  session           RecommendationTelemetrySession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  candidateSnapshot RecommendationCandidateSnapshot? @relation(fields: [candidateSnapshotId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([projectId])
  @@index([eventType])
  @@index([eventTimestamp])
  @@index([recommendationRunId])
}

/// Post-install real-world outcome (separate from per-species OutcomeEvent).
model InstallOutcomeRecord {
  id                               String    @id @default(cuid())
  projectId                        String
  userId                           String?
  telemetrySessionId               String?
  selectedCandidateSnapshotId      String?
  installerId                      String?
  installStatus                    String
  installDate                      DateTime?
  actualInstallCostInr             Float?
  actualMaintenancePlanInr         Float?
  installedAreaSqft                Float?
  irrigationInstalled              Boolean?
  speciesInstalledJson             String?
  deviationsFromRecommendationJson String?
  userSatisfactionScore            Float?
  installerFeasibilityRating       Float?
  measuredTempChangeC              Float?
  measuredSurfaceTempChangeC       Float?
  plantSurvivalRate30d             Float?
  plantSurvivalRate90d             Float?
  maintenanceAdherenceScore        Float?
  notes                            String?
  idempotencyKey                   String?   @unique
  createdAt                        DateTime  @default(now())

  project                 Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                    User?                            @relation(fields: [userId], references: [id], onDelete: SetNull)
  telemetrySession        RecommendationTelemetrySession?  @relation(fields: [telemetrySessionId], references: [id], onDelete: SetNull)
  selectedCandidateSnapshot RecommendationCandidateSnapshot? @relation(fields: [selectedCandidateSnapshotId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([telemetrySessionId])
  @@index([installStatus])
}

/// Ranked recommendation slot; optional primary species + funnel flags for training and analytics.
model RecommendationCandidate {
  id                   String   @id @default(cuid())
  runId                String
  run                  RecommendationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  rank                 Int
  /// Model or blended relevance score for ranking (tabular export may omit to avoid leakage).
  rankScore            Float?
  recommendationId     String
  layoutName           String
  headline             String?
  summary              String?
  costEstimate         String
  heatEstimate         String
  layoutSchema         String
  spatialMapping       String?
  heatReductionSummary String?
  /// Primary species for this row (multi-species layouts: use multiple candidate rows or JSON in layoutSchema).
  speciesId            String?
  species              SpeciesCatalog? @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  /// Denormalized `SpeciesCatalog.code` for training exports / linkage when FK optional or not yet seeded.
  speciesCatalogCode   String?
  shown                Boolean  @default(false)
  clicked              Boolean  @default(false)
  saved                Boolean  @default(false)
  accepted             Boolean  @default(false)
  installed            Boolean  @default(false)
  createdAt            DateTime @default(now())
  feedbackEvents       RecommendationFeedbackEvent[]
  selectedInSessions   PhotoSession[] @relation("SelectedPhotoSession")
  outcomeEvents        OutcomeEvent[]

  @@index([runId])
  @@index([speciesId])
  @@index([speciesCatalogCode])
  @@index([runId, rank])
}

/// Longitudinal plant outcomes (survival, removal); append-only or updated follow-ups — separate from funnel flags on RecommendationCandidate.
model OutcomeEvent {
  id          String   @id @default(cuid())
  runId       String
  run         RecommendationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  candidateId String?
  candidate   RecommendationCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  speciesId   String
  species     SpeciesCatalog @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  /// e.g. SURVIVAL_30D | SURVIVAL_90D | REMOVAL | HEALTH_CHECK | INSTALL_CONFIRM
  eventKind   String
  survived30d   Boolean?
  survived90d   Boolean?
  removed       Boolean  @default(false)
  removedReason String?
  healthScore   Float?
  source        String?
  metadataJson  String?
  recordedAt    DateTime @default(now())

  @@index([runId])
  @@index([speciesId])
  @@index([candidateId])
  @@index([eventKind])
  @@index([recordedAt])
}

model PhotoSession {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  projectId              String?
  userId                 String?
  capturedAt             DateTime?
  photoData              String?
  photoMime              String?
  photoWidth             Int?
  photoHeight            Int?
  measurementStatus      String?
  widthM                 Float?
  lengthM                Float?
  floorLevel             Int?
  measurementCompletedAt DateTime?
  recommendationJson     String?
  layoutSchema           String?
  spatialMapping         String?
  visualizationImageUrl  String?
  visualizationPrompt    String?
  selectedCandidateId    String?
  selectedCandidate      RecommendationCandidate? @relation("SelectedPhotoSession", fields: [selectedCandidateId], references: [id])
  environmentSnapshotId  String?
  environmentSnapshot    EnvironmentSnapshot?     @relation(fields: [environmentSnapshotId], references: [id], onDelete: SetNull)
  /// JSON: { projectMeta?, environment? } — client restore; normalized rows are source of truth for environment when linked.
  sessionContextJson     String?                  @map("session_context_json")
  visualizationRecords   VisualizationRecord[]
  pipelineEvents         PhotoPipelineEvent[]
  recommendationRuns     RecommendationRun[]
  telemetrySessions      RecommendationTelemetrySession[]

  @@index([environmentSnapshotId])
}

model PhotoPipelineEvent {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  photoSessionId String
  action         String
  userId         String?
  projectId      String?
  payload        String?

  photoSession   PhotoSession @relation(fields: [photoSessionId], references: [id])
}

model VisualizationRecord {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  photoSessionId      String?
  photoSession        PhotoSession? @relation(fields: [photoSessionId], references: [id])
  sourcePhotoRef      String?
  recommendationId    String
  layoutSchema        String
  spatialMapping      String
  visualizationPrompt String
  generatedImageUrl   String
  generationVersion   Int           @default(1)
}

/// Network partner — capability and coverage (verified-outcomes / installer ops).
model InstallerProfile {
  id                          String   @id @default(cuid())
  installerName               String
  serviceRegionsJson          String   @default("[]")
  supportedProjectTypesJson   String   @default("[]")
  supportedSolutionTypesJson  String   @default("[]")
  supportedBudgetBandsJson    String   @default("[]")
  minJobSizeSqft              Float    @default(0)
  maxJobSizeSqft              Float?
  irrigationCapability        Boolean  @default(false)
  structuralInstallCapability Boolean  @default(false)
  shadeSystemCapability       Boolean  @default(false)
  edibleGardenCapability      Boolean  @default(false)
  maintenanceServiceAvailable Boolean  @default(false)
  averageRating               Float?
  jobsCompletedCount          Int      @default(0)
  verificationStatus          String   @default("pending")
  activeStatus                String   @default("active")
  metadataJson                String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  quoteAssignments InstallerQuoteAssignment[]
  quotes           InstallerQuote[]
  installJobs      InstallerInstallJob[]
  verifiedInstalls VerifiedInstallRecord[]
  revenueEvents              RevenueEvent[]
  leadFunnelEvents           LeadFunnelEvent[]
  commercialMetricsSnapshots InstallerCommercialMetrics[]
  partnerOperationsProfile   PartnerOperationsProfile?
  partnerCapabilityMatrix  PartnerCapabilityMatrix?
  partnerFieldOpsStatus      PartnerFieldOpsStatus?
  partnerSlaMetrics          PartnerSLAMetrics[]

  @@index([activeStatus])
  @@index([verificationStatus])
}

/// Partner-level org & compliance (extends single-installer `InstallerProfile` for field network scale-up).
model PartnerOperationsProfile {
  id                   String           @id @default(cuid())
  installerId          String           @unique
  installer            InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  organizationName     String?
  legalEntityName      String?
  serviceAreasJson     String           @default("[]")
  complianceStatus   String           @default("pending")
  partnerActiveStatus  String           @default("operational")
  primaryContactJson   String?
  metadataJson         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([complianceStatus])
  @@index([partnerActiveStatus])
}

/// Capability matrix: project/solution types, complexity, seasonality, readiness.
model PartnerCapabilityMatrix {
  id                      String           @id @default(cuid())
  installerId             String           @unique
  installer               InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  projectTypesJson        String           @default("[]")
  solutionTypesJson       String           @default("[]")
  complexityBandsJson     String           @default("[]")
  seasonalConstraintsJson String           @default("{}")
  serviceReadiness        String           @default("ready")
  matrixExtrasJson        String?
  updatedAt               DateTime         @updatedAt

  @@index([serviceReadiness])
}

/// Live field-ops signals: availability, pauses, overload, regional readiness / coverage gaps.
model PartnerFieldOpsStatus {
  id                    String           @id @default(cuid())
  installerId           String           @unique
  installer             InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  availabilityState     String           @default("available")
  pauseState            String?
  overloadSignal        String           @default("none")
  coverageGapsJson      String?
  regionalReadinessJson String           @default("{}")
  signalNotesJson       String?
  updatedAt             DateTime         @updatedAt

  @@index([availabilityState])
}

/// Rolling SLA-style metrics per installer and time window (from quotes, jobs, verifications).
model PartnerSLAMetrics {
  id                       String           @id @default(cuid())
  installerId              String
  installer                InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  windowStart              DateTime
  windowEnd                DateTime
  responseTimeMsP50        Int?
  quoteTurnaroundHoursP50  Float?
  siteVisitCompletionRate  Float?
  installStartDelayDaysP50 Float?
  verificationDelayDaysP50 Float?
  jobSampleSize            Int              @default(0)
  metadataJson             String?
  computedAt               DateTime         @default(now())

  @@unique([installerId, windowStart, windowEnd])
  @@index([installerId, computedAt])
}

/// User-initiated quote flow tied to recommendation context (snapshots for reproducibility).
model InstallerQuoteRequest {
  id                          String   @id @default(cuid())
  projectId                   String
  userId                      String?
  recommendationSessionId     String?
  selectedCandidateSnapshotId String?
  requestStatus               String   @default("submitted")
  requestedAt                 DateTime @default(now())
  userLocationRegion          String
  projectSnapshotJson         String
  candidateSnapshotJson       String?
  notes                       String?

  project               Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                  User?                            @relation(fields: [userId], references: [id], onDelete: SetNull)
