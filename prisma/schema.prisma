  explanationProvenanceJson      String
  metadataJson                   String?

  project                  Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                     User?                            @relation(fields: [userId], references: [id], onDelete: SetNull)
  recommendationSession    RecommendationTelemetrySession @relation(fields: [recommendationSessionId], references: [id], onDelete: Cascade)
  selectedCandidateSnapshot RecommendationCandidateSnapshot? @relation("DossierSelectedCandidate", fields: [selectedCandidateSnapshotId], references: [id], onDelete: SetNull)
  reportSections           ReportSection[]
  reportExplanations       ReportExplanation[]
  installerExecutionSummary InstallerExecutionSummary?
  adminReviewDossier        AdminReviewDossier?

  @@index([projectId])
  @@index([recommendationSessionId])
  @@index([dossierType])
  @@index([generatedAt])
}

model ReportSection {
  id                     String   @id @default(cuid())
  recommendationDossierId String
  sectionKey             String
  sectionOrder           Int
  sectionTitle           String
  sectionType            String
  sectionPayloadJson     String
  explanationRefsJson    String?
  visibilityScope        String
  createdAt              DateTime @default(now())

  dossier RecommendationDossier @relation(fields: [recommendationDossierId], references: [id], onDelete: Cascade)

  @@index([recommendationDossierId])
  @@index([sectionKey])
}

model ReportExplanation {
  id                      String   @id @default(cuid())
  recommendationDossierId String
  relatedSectionKey       String
  explanationType         String
  sourceLayer             String
  sourceReferenceId       String?
  explanationPayloadJson  String
  confidenceBand          String?
  createdAt               DateTime @default(now())

  dossier RecommendationDossier @relation(fields: [recommendationDossierId], references: [id], onDelete: Cascade)

  @@index([recommendationDossierId])
  @@index([sourceLayer])
}

/// Execution-oriented slice linked 1:1 to a dossier (installer-facing).
model InstallerExecutionSummary {
  id                      String   @id @default(cuid())
  recommendationDossierId String   @unique
  projectId               String
  installJobId            String?
  executionPayloadJson    String
  readinessChecklistJson  String?
  metadataJson            String?
  createdAt               DateTime @default(now())

  dossier    RecommendationDossier  @relation(fields: [recommendationDossierId], references: [id], onDelete: Cascade)
  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installJob InstallerInstallJob?  @relation(fields: [installJobId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([installJobId])
}

/// Admin risk / audit slice linked 1:1 to a dossier.
model AdminReviewDossier {
  id                      String   @id @default(cuid())
  recommendationDossierId String   @unique
  reviewPayloadJson       String
  riskAssessmentJson      String?
  provenanceAuditJson     String?
  metadataJson            String?
  createdAt               DateTime @default(now())

  dossier RecommendationDossier @relation(fields: [recommendationDossierId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

/// Aggregated learning / KPI snapshot for a time window (admin & retraining signals).
model RecommendationInsight {
  id                      String   @id @default(cuid())
  windowStart             DateTime
  windowEnd               DateTime
  insightType             String
  scopeJson               String
  metricsJson             String
  evidenceRefsJson        String
  sourceLayersJson        String
  recommendationDossierId String?
  createdAt               DateTime @default(now())
  metadataJson            String?

  @@index([windowStart, windowEnd])
  @@index([insightType])
}

/// Rollup by generator/rules/model and optional experiment / variant labels.
model VariantPerformance {
  id                       String   @id @default(cuid())
  windowStart              DateTime
  windowEnd                DateTime
  experimentId             String?
  rolloutVariant           String?
  recommendationType       String?
  scenarioUsageTag         String?
  reportDossierType        String?
  generatorSource          String?
  rulesVersion             String?
  modelVersion             String?
  sessionCount             Int      @default(0)
  candidateCount           Int      @default(0)
  avgBlendedScore          Float?
  avgLatencyMs             Float?
  verifiedInstallCount     Int      @default(0)
  dossierCreatedCount      Int      @default(0)
  followupCompletedCount   Int      @default(0)
  commercialInstalledCount Int      @default(0)
  createdAt                DateTime @default(now())
  metadataJson             String?

  @@index([windowStart, windowEnd])
  @@index([experimentId, rolloutVariant])
  @@index([generatorSource, rulesVersion])
}

/// Performance slice by coarse product / market / personalization dimensions.
model SegmentPerformance {
  id                            String   @id @default(cuid())
  windowStart                   DateTime
  windowEnd                     DateTime
  segmentKey                    String
  projectType                   String?
  climateZone                   String?
  budgetBand                    String?
  region                        String?
  userType                      String?
  installerAvailabilityBand     String?
  personalizationConfidenceBand String?
  metricsJson                   String
  sampleSize                    Int
  createdAt                     DateTime @default(now())
  metadataJson                  String?

  @@index([windowStart, windowEnd])
  @@index([segmentKey])
}

/// Auditable structured lesson memory (evidence-backed; not generative doctrine).
model LessonMemory {
  id                                String    @id @default(cuid())
  lessonKey                         String    @unique
  polarity                          String
  confidenceBand                    String
  summaryStructuredJson             String
  evidenceRefsJson                  String
  relatedSegmentKey                 String?
  relatedRecommendationPatternsJson String?
  effectiveFrom                     DateTime?
  effectiveTo                       DateTime?
  createdBy                         String    @default("system")
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt
  metadataJson                      String?

  @@index([polarity])
  @@index([confidenceBand])
}

/// Append-only integration audit event (CRM, partners, payments, analytics sinks, etc.).
model IntegrationEvent {
  id              String   @id @default(cuid())
  eventType       String
  domain          String
  sourceSystem    String?
  targetSystem    String?
  entityType      String?
  entityId        String?
  payloadJson     String
  correlationId   String?
  createdAt       DateTime @default(now())
  metadataJson    String?

  @@index([domain, createdAt])
  @@index([eventType])
  @@index([correlationId])
  @@index([entityType, entityId])
}

/// Outbound sync job to an external system (retry-friendly, not append-only row updates).
model OutboundSync {
  id                 String    @id @default(cuid())
  targetSystem       String
  entityType         String
  entityId           String
  payloadSnapshotJson String
  syncStatus         String    @default("pending")
  attemptCount       Int       @default(0)
  lastAttemptAt      DateTime?
  nextRetryAt        DateTime?
  errorCode          String?
  errorDetailJson    String?
  idempotencyKey     String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  metadataJson       String?

  @@index([targetSystem, syncStatus])
  @@index([entityType, entityId])
  @@index([nextRetryAt])
}

/// Inbound webhook envelope (append-only; duplicate detection via source + external id).
model InboundWebhook {
  id                          String    @id @default(cuid())
  sourceSystem                String
  externalEventId             String?
  eventType                   String
  payloadJson                 String
  validationStatus            String    @default("received")
  receivedAt                  DateTime  @default(now())
  processedAt                 DateTime?
  linkageProjectId            String?
  linkageUserId               String?
  linkageRecommendationSessionId String?
  duplicateOfWebhookId        String?
  metadataJson                String?

  @@unique([sourceSystem, externalEventId])
  @@index([sourceSystem, receivedAt])
  @@index([validationStatus])
}

/// Delivery lifecycle for reports, notifications, and partner pushes.
model DeliveryTracking {
  id                   String    @id @default(cuid())
  deliveryType         String
  channel              String
  targetRef            String
  relatedEntityType    String?
  relatedEntityId      String?
  deliveryStatus       String    @default("queued")
  attemptCount         Int       @default(0)
  lastAttemptAt        DateTime?
  lastStatusDetailJson String?
  correlationId        String?
  outboundSyncId       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  metadataJson         String?

  @@index([deliveryType, deliveryStatus])
  @@index([correlationId])
  @@index([outboundSyncId])
}

/// Append-only platform audit trail for sensitive / business-critical actions.
model PlatformAuditEvent {
  id              String   @id @default(cuid())
  auditEventType  String
  subsystem       String
  actorType       String
  actorId         String?
  entityType      String?
  entityId        String?
  action          String
  outcome         String
  severity        String   @default("info")
  payloadJson     String
  correlationId   String?
  createdAt       DateTime @default(now())
  metadataJson    String?

  @@index([subsystem, createdAt])
  @@index([auditEventType])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([actorType, actorId])
}

/// Idempotency reservations for critical writes (telemetry, quotes, installs, outcomes, revenue).
model IdempotencyRecord {
  id               String    @id @default(cuid())
  scope            String
  idempotencyKey   String
  requestHash      String?
  status           String    @default("in_flight")
  httpStatus       Int?
  responseBodyJson String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@unique([scope, idempotencyKey])
  @@index([scope, createdAt])
  @@index([status])
}

/// User consent for sensitive workflows (media, telemetry sharing, installer data, follow-ups, analytics).
model UserConsentRecord {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentScope   String
  consentStatus  String    @default("granted")
  sourceChannel  String?
  grantedAt      DateTime?
  withdrawnAt    DateTime?
  expiresAt      DateTime?
  legalBasis     String?
  metadataJson   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, consentScope])
  @@index([consentScope, consentStatus])
}

/// Risk / quality / anomaly flags for governance workflows.
model GovernancePolicyFlag {
  id           String    @id @default(cuid())
  flagType     String
  severity     String
  status       String    @default("open")
  entityType   String?
  entityId     String?
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  detailJson   String?
  raisedAt     DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?
  metadataJson String?

  @@index([status, severity])
  @@index([flagType])
  @@index([entityType, entityId])
}

/// Configurable retention parameters per major entity category (summary rows for ops / DPA appendices).
model DataRetentionCategoryPolicy {
  id                   String   @id @default(cuid())
  entityCategory       String   @unique
  defaultRetentionDays Int
  archiveAfterDays     Int?
  hardDeleteAfterDays  Int?
  notesJson            String?
  policyVersion        String   @default("v1")
  updatedAt            DateTime @updatedAt

  @@index([entityCategory])
}

/// Internal governance review queue for sensitive or high-risk cases.
model GovernanceReviewRecord {
  id                String    @id @default(cuid())
  reviewType        String
  status            String    @default("queued")
  priority          String    @default("normal")
  subjectEntityType String
  subjectEntityId   String
  relatedUserId     String?
  relatedUser       User?     @relation("GovernanceReviewRelatedUser", fields: [relatedUserId], references: [id], onDelete: SetNull)
  relatedProjectId  String?
  relatedProject    Project?  @relation("GovernanceReviewRelatedProject", fields: [relatedProjectId], references: [id], onDelete: SetNull)
  openedByActorId   String?
  openedByActorType String?
  findingsJson      String?
  resolutionSummary String?
  assignedToActorId String?
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  metadataJson      String?

  @@index([status, priority])
  @@index([subjectEntityType, subjectEntityId])
  @@index([openedAt])
}
