  updatedAt             DateTime @updatedAt

  project           Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  verifiedInstall   VerifiedInstallRecord?   @relation(fields: [verifiedInstallId], references: [id], onDelete: SetNull)
  checkpoints       LongitudinalFollowupCheckpoint[]
  remeasurements    LongitudinalRemeasurement[]

  @@index([projectId])
  @@index([baselineAt])
  @@index([scheduleStatus])
}

model LongitudinalFollowupCheckpoint {
  id                 String    @id @default(cuid())
  scheduleId         String
  offsetDays         Int
  windowLabel        String
  dueAt              DateTime
