  selectedCandidate     RecommendationCandidateSnapshot? @relation(fields: [selectedCandidateSnapshotId], references: [id], onDelete: SetNull)
  assignments           InstallerQuoteAssignment[]
  quotes                InstallerQuote[]
  jobs                  InstallerInstallJob[]
  revenueEvents         RevenueEvent[]
  leadFunnelEvents      LeadFunnelEvent[]

  @@index([projectId])
  @@index([requestStatus])
}

/// One installer invited to bid on a quote request.
model InstallerQuoteAssignment {
  id                       String    @id @default(cuid())
  quoteRequestId           String
  installerId              String
  assignmentStatus         String    @default("invited")
  assignedAt               DateTime  @default(now())
  declinedAt               DateTime?
  rejectionReasonCodesJson String?

  quoteRequest InstallerQuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  installer    InstallerProfile      @relation(fields: [installerId], references: [id], onDelete: Cascade)
  quotes       InstallerQuote[]

  @@unique([quoteRequestId, installerId])
  @@index([installerId])
}

model InstallerQuote {
  id                                   String   @id @default(cuid())
  quoteRequestId                       String
  quoteAssignmentId                    String
  installerId                          String
  quotedAt                             DateTime @default(now())
  quoteStatus                          String   @default("submitted")
  quoteAmountInr                       Float
  estimatedTimelineDays                Int
  includedScopeJson                    String
  excludedScopeJson                    String?
  proposedSpeciesJson                  String?
  proposedMaterialsJson                String?
  notes                                String?
  deviationFromRecommendationFlagsJson String?

  quoteRequest    InstallerQuoteRequest    @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  quoteAssignment InstallerQuoteAssignment @relation(fields: [quoteAssignmentId], references: [id], onDelete: Cascade)
  installer       InstallerProfile         @relation(fields: [installerId], references: [id], onDelete: Cascade)
  installJobs     InstallerInstallJob[]
  quoteComparisonRecords QuoteComparisonRecord[]
  revenueEvents          RevenueEvent[]
  leadFunnelEvents       LeadFunnelEvent[]

  @@index([quoteRequestId])
  @@index([installerId])
  @@index([quoteStatus])
}

/// Executable install after quote acceptance.
model InstallerInstallJob {
  id                          String    @id @default(cuid())
  quoteRequestId              String
  projectId                   String
  userId                      String?
  installerId                 String
  sourceQuoteId               String?
  selectedCandidateSnapshotId String?
  jobStatus                   String    @default("scheduled")
